RPC_URL=http://127.0.0.1:8545

# Hardhat local account #2 from `npx hardhat node`.
# This must be the oracle signer printed by scripts/deploy.ts.
PRIVATE_KEY=put_oracle_private_key_here
USER_PRIVATE_KEY=put_user_private_key_here

TOKEN_ADDRESS=put_mock_token_address_here
CONTRACT_ADDRESS=put_challenge_contract_address_here

CHALLENGE_ID=1
CHALLENGE_HANDLE=tourist
START_DELAY_SECONDS=300
PERIOD_DURATION_SECONDS=300
CYCLE_DURATION_SECONDS=300
TOTAL_PERIODS=3
MIN_RATING=800
PENALTY_NO_SUBMISSION=10
PENALTY_NO_OK=5
AUTOPILOT_POLL_INTERVAL_SECONDS=15
AUTOPILOT_START_DELAY_SECONDS=5
ORACLE_LOOP_INTERVAL_SECONDS=70

TREASURY_WITHDRAW_AMOUNT=15
